DATABASE_URL=
ADMIN_PASSWORD=
SESSION_SECRET=
# 任意。公開設定したR2バケットのベースURL。設定時は管理フォームから画像をR2へアップロードできる
R2_PUBLIC_URL=
# 任意。本番URL（OGPの絶対URL生成に使用）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 任意。スポット詳細の「場所・アクセス」でGoogle Maps Embed APIを使う。
# 未設定ならGoogleマップへのリンクにフォールバック。Embed APIに限定＋HTTPリファラ制限を推奨。
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
