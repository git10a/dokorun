# DBはCloudflare D1(ローカルは .wrangler/state のsqlite、本番はD1バインディング)。
# 接続文字列は不要。CLIスクリプトの参照先を切り替える場合は D1_LOCAL_PATH=<sqliteファイル> を使う。
ADMIN_PASSWORD=
SESSION_SECRET=
# 任意。公開設定したR2バケットのベースURL。設定時は管理フォームから画像をR2へアップロードできる
R2_PUBLIC_URL=
# 任意。本番URL（OGPの絶対URL生成に使用）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 会員認証(Better Auth)。SECRETは32文字以上のランダム値
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
