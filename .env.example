# デプロイ(npm run deploy)は本番Neonの DATABASE_URL が必須。
# コマンドライン引数では渡さず、プロジェクト直下に.env.production(gitignore済み)を作成して
# DATABASE_URL=<本番NeonのURL> だけを書く。作成後は `chmod 600 .env.production` を推奨。
DATABASE_URL=
ADMIN_PASSWORD=
SESSION_SECRET=
# 任意。公開設定したR2バケットのベースURL。設定時は管理フォームから画像をR2へアップロードできる
R2_PUBLIC_URL=
# 任意。本番URL（OGPの絶対URL生成に使用）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 会員認証(Better Auth)。SECRETは32文字以上のランダム値
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
