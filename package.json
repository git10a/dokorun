{
  "name": "dokorun",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/sync-public-spot-gpx.mjs && next build",
    "start": "next start",
    "preview": "node scripts/sync-public-spot-gpx.mjs && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "predeploy": "node scripts/d1-snapshot.mjs",
    "deploy": "bash scripts/deploy.sh",
    "release:upload": "bash scripts/deploy.sh",
    "release:smoke": "node scripts/smoke-production.mjs",
    "release:promote": "node scripts/release.mjs",
    "release:rollback": "node scripts/rollback.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "db:import": "tsx src/db/import.ts",
    "db:exclusions": "tsx src/db/exclusions.ts",
    "research:runtrip": "node scripts/research/fetch-runtrip-popular.mjs",
    "gpx:apply": "tsx scripts/apply-gpx.ts",
    "gpx:backfill": "tsx scripts/backfill-simplified-geojson.ts",
    "gpx:check": "tsx scripts/check-gpx.ts",
    "course-guide:build": "tsx scripts/build-course-guide.ts",
    "course-guide:audit": "tsx scripts/audit-course-guide-coverage.ts",
    "course-guide:research": "tsx scripts/collect-course-guide-research.ts",
    "course-guide:evaluate": "tsx scripts/evaluate-course-guide-research.ts",
    "course-guide:elevation": "tsx scripts/backfill-course-guide-elevation.ts",
    "course-guide:generate": "tsx scripts/generate-course-guide-sources.ts",
    "course-guide:photos": "tsx scripts/supplement-course-guide-photos.ts",
    "race-gpx:apply": "tsx scripts/apply-race-gpx.ts",
    "validate:spots": "tsx scripts/validate-spots.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "@next/bundle-analyzer": "^16.2.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.10",
    "fast-xml-parser": "^5.9.3",
    "postgres": "^3.4.9",
    "puppeteer-core": "^24.43.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.86.0"
  }
}
